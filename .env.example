PORT=5173
HOST=127.0.0.1

# mock: only use generated demo jobs
# api: call the authorized endpoints below, then fall back to generated jobs when unavailable
JOB_SOURCE_MODE=mock

# Optional authorized job data endpoints.
# CareerMap calls each endpoint with ?keyword=<targetRole>&city=<city>&platform=<provider>.
# Expected response can be an array, or { "jobs": [...] }, { "data": [...] }, { "results": [...] }.
BOSS_JOBS_ENDPOINT=
LIEPIN_JOBS_ENDPOINT=
JOB51_JOBS_ENDPOINT=
LINKEDIN_JOBS_ENDPOINT=

# Optional bearer tokens. JOBS_API_KEY is used as a shared fallback token.
JOBS_API_KEY=
BOSS_API_KEY=
LIEPIN_API_KEY=
JOB51_API_KEY=
LINKEDIN_API_KEY=
